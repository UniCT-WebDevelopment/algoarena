{
  "name": "algo-arena",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "github-build": "ng build --configuration production --base-href 'https://Modz54Ita.github.io/algo-arena/'",
    "github-deploy": "npx angular-cli-ghpages --dir=dist/algo-arena/browser --no-silent",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "runner": "node runner/index.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.13",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.13",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "backbone": "^1.6.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jointjs": "^3.7.7",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "monaco-editor": "^0.52.2",
    "mongoose": "^8.12.1",
    "ngx-monaco-editor-v2": "^20.3.0",
    "pdf-parse": "^1.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.11",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.22",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.9.2"
  }
}
